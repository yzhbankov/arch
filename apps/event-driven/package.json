{
    "name": "event-driven",
    "version": "1.0.0",
    "description": "",
    "main": "apps/event-driven/dist/app.js",
    "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.9.2"
    },
    "scripts": {
        "start": "node dist/app.js",
        "start:dev": "tsx app.ts",
        "build": "cross-env NODE_ENV=production tsc && tsc-alias && copyfiles -u 1 config/*.json dist/config && cp .env* dist/",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint --fix './**/*.ts'",
        "reset": "yarn clean && yarn",
        "clean": "rimraf dist && rimraf node_modules"
    },
    "license": "UNLICENSED",
    "devDependencies": {
        "@types/dotenv-defaults": "^2.0.4",
        "@types/node": "^22.13.10",
        "@typescript-eslint/eslint-plugin": "^8.26.0",
        "@typescript-eslint/parser": "^8.26.0",
        "copyfiles": "^2.4.1",
        "eslint": "^9.22.0",
        "eslint-plugin-import": "^2.31.0",
        "prettier": "^3.5.3",
        "tsc-alias": "^1.8.13",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.0"
    },
    "dependencies": {
        "@redis/client": "^5.8.2",
        "cross-env": "^7.0.3",
        "dotenv": "^16.4.7",
        "dotenv-defaults": "^5.0.2",
        "ioredis": "^5.7.0",
        "livr": "^2.8.1",
        "livr-extra-rules": "^1.4.0",
        "redis": "^4.7.0",
        "zeromq": "^6.3.0"
    }
}
